#!/bin/bash
set -euo pipefail

# Load configuration
CONFIG_FILE="$HOME/secret/restic_backup.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Configuration file not found: $CONFIG_FILE"
    exit 1
fi

# Source config variables
source "$CONFIG_FILE"

# Verify required variables are set
for var in RESTIC_PASSWD BACKUP_SOURCE BACKUP_REPO MUSIC_SOURCE PICTURES_SOURCE; do
    if [[ -z "${!var:-}" ]]; then
        echo "Error: $var is not set in $CONFIG_FILE"
        exit 1
    fi
done

# Retention policy (how many backups to keep)
KEEP_OPTIONS="--keep-hourly 2 --keep-daily 5 --keep-weekly 3 --keep-monthly 4"

echo "=== Unlocking repository ==="
restic -p "$RESTIC_PASSWD" -r "$BACKUP_REPO" unlock

echo "=== Starting backup of $BACKUP_SOURCE using restic ==="
# $BACKUP_SOURCE not in quotes so that multiple strings are seen as
# multiple arguments.
restic -p "$RESTIC_PASSWD" -r "$BACKUP_REPO" --compression max backup $BACKUP_SOURCE

#echo "=== Applying retention policy ==="
#restic -p "$RESTIC_PASSWD" -r "$BACKUP_REPO" forget $KEEP_OPTIONS --prune --cleanup-cache

echo "=== Synchronising music from $MUSIC_SOURCE ==="
# Add trailing / for source dirs: its name might be different from the one on the remote server.
# rsync does *not* support renaming files/reorganising directory structures. It will just re-copy stuff.
# --fuzzy --delay-updates --delete-delay at least alleviates some of the deduplication.
rsync -aPvh --delay-updates --delete-delay --exclude ".snapshots" --out-format="%i | %M |  %n" --stats "$MUSIC_SOURCE/" "$MUSIC_TARGET"

echo "=== Synchronising pictures from $PICTURES_SOURCE ==="
rsync -aPvh --delay-updates --delete-delay --exclude ".snapshots" --out-format="%i | %M |  %n" --stats "$PICTURES_SOURCE/" "$PICTURES_TARGET"

echo "=== Backup completed successfully ==="
