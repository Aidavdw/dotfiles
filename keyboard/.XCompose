<Multi_key> <space> <space>		: " "	nobreakspace # NO-BREAK SPACE
<Multi_key> <period> <period>		: "…"	ellipsis # HORIZONTAL ELLIPSIS

# Math
<Multi_key> <plus> <minus>              : "±"   plusminus # PLUS-MINUS SIGN
<Multi_key> <minus> <plus>              : "±"   plusminus # PLUS-MINUS SIGN
<Multi_key> <p> <m>              : "±"   plusminus # PLUS-MINUS SIGN
<Multi_key><d><e><g>: "°"
<Multi_key><e><q>: "⇄"
<Multi_key><p><d>: "∂"
<Multi_key><g><r><a><d>: "∇"
<Multi_key><p><r><o><d>: "∏"
<Multi_key><s><q><r><t>: "√"
<Multi_key><i><n><f>: "∞"
<Multi_key><p><t>: "∝"
<Multi_key><a><p>: "≈"
<Multi_key><n><e>: "≠"
<Multi_key><s><u><m>: "Σ"

# Ligatures
<Multi_key><s><s>: "ß"
<Multi_key><i><j>                     : "ĳ"   U0133 # LATIN SMALL LIGATURE IJ
<Multi_key> <I> <j>                     : "Ĳ"   U0132 # LATIN CAPITAL LIGATURE IJ
<Multi_key> <I> <J>                     : "Ĳ"   U0132 # LATIN CAPITAL LIGATURE IJ
<Multi_key> <a> <e>                     : "æ"   ae # LATIN SMALL LETTER AE
<Multi_key> <A> <E>                     : "Æ"   AE # LATIN CAPITAL LETTER AE
<Multi_key> <o> <e>                     : "œ"   oe # LATIN SMALL LIGATURE OE
<Multi_key> <O> <E>                     : "Œ"   OE # LATIN CAPITAL LIGATURE OE

# Brackets and quotation marks
<Multi_key> <less> <less>               : "«"   guillemotleft # LEFT-POINTING DOUBLE ANGLE QUOTATION MARK
<Multi_key> <greater> <greater>         : "»"   guillemotright # RIGHT-POINTING DOUBLE ANGLE QUOTATION MARK

# Currencies
<Multi_key><y><e><n>: "¥"
<Multi_key><j><p><y>: "¥"
<Multi_key><e><u><r>: "€"
<Multi_key><g><b><p>: "£"

# Music
<Multi_key> <m> <f>            : "♭"   U266d # MUSIC FLAT SIGN
<Multi_key> <m> <n>            : "♮"   U266e # MUSIC NATURAL SIGN
<Multi_key> <m> <s>   : "♯"   U266f # MUSIC SHARP SIGN

# Superscripts & subscripts
# Arranged like the keypad in graphre layout
<Multi_key><S><y>: "⁰"
<Multi_key><S><p>: "¹"
<Multi_key><S><comma>: "²"
<Multi_key><S><period>: "³"
<Multi_key><S><h>: "⁴"
<Multi_key><S><a>: "⁵"
<Multi_key><S><e>: "⁶"
<Multi_key><S><f>: "⁷"
<Multi_key><S><o>: "⁸"
<Multi_key><S><u>: "⁹"
<Multi_key><S><minus><p>: "⁻¹"
<Multi_key><S><minus><comma>: "⁻²"
<Multi_key><S><minus><period>: "⁻³"
<Multi_key><S><minus><h>: "⁻⁴"
<Multi_key><S><minus><a>: "⁻⁵"
<Multi_key><S><minus><e>: "⁻⁶"
<Multi_key><S><minus><f>: "⁻⁷"
<Multi_key><S><minus><o>: "⁻⁸"
<Multi_key><S><minus><u>: "⁻⁹"

<Multi_key><s><y>: "₀"
<Multi_key><s><p>: "₁"
<Multi_key><s><comma>:"₂"
<Multi_key><s><period>:"₃"
<Multi_key><s><h>: "₄"
<Multi_key><s><a>: "₅"
<Multi_key><s><e>: "₆"
<Multi_key><s><f>: "₇"
<Multi_key><s><o>: "₈"
<Multi_key><s><minus><p>: "₋₁"
<Multi_key><s><minus><comma>:"₋₂"
<Multi_key><s><minus><period>:"₋₃"
<Multi_key><s><minus><h>: "₋₄"
<Multi_key><s><minus><a>: "₋₅"
<Multi_key><s><minus><e>: "₋₆"
<Multi_key><s><minus><f>: "₋₇"
<Multi_key><s><minus><o>: "₋₈"
